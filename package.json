{
  "name": "perplexity-mcp-zerver",
  "version": "0.4.0",
  "description": "MCP server using Perplexity API for AI-powered research capabilities.",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint": "biome lint . --write",
    "format": "biome format . --write",
    "dev": "npm run build && npm run start"
  },
  "keywords": [
    "mcp",
    "perplexity",
    "api",
    "ai",
    "research"
  ],
  "author": "sm-moshi",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "0.6.0",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.0.0",
    "jsdom": "26.1.0",
    "minimist": "1.2.8",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "21.1.7",
    "@types/minimist": "1.2.5",
    "@types/node": "22.15.30",
    "@vitest/coverage-v8": "3.2.2",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  }
}
